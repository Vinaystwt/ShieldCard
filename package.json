{
	"name": "shieldcard",
	"version": "0.3.1",
	"description": "ShieldCard confidential corporate spend-policy engine for the Fhenix Buildathon",
	"scripts": {
		"test": "REPORT_GAS=true hardhat test",
		"clean": "rimraf ./artifacts ./cache ./coverage ./types ./coverage.json ./deployments/localcofhe",
		"compile": "hardhat compile",
		"shieldcard:deploy": "hardhat run scripts/deploy.ts",
		"shieldcard:seed-demo": "hardhat run scripts/seed-demo.ts",
		"arb-sepolia:deploy": "hardhat run scripts/deploy.ts --network arb-sepolia",
		"arb-sepolia:seed-demo": "hardhat run scripts/seed-demo.ts --network arb-sepolia",
		"arb-sepolia:publish-results": "hardhat run scripts/publish-results.ts --network arb-sepolia",
		"arb-sepolia:verify-seed": "hardhat run scripts/verify-seed.ts --network arb-sepolia",
		"arbitrumSepolia:deploy": "hardhat run scripts/deploy.ts --network arbitrumSepolia",
		"arbitrumSepolia:seed-demo": "hardhat run scripts/seed-demo.ts --network arbitrumSepolia",
		"base-sepolia:deploy": "hardhat run scripts/deploy.ts --network base-sepolia"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Vinaystwt/ShieldCard.git"
	},
	"author": "Vinay",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/Vinaystwt/ShieldCard/issues"
	},
	"homepage": "https://github.com/Vinaystwt/ShieldCard#readme",
	"devDependencies": {
		"@fhenixprotocol/cofhe-contracts": "^0.1.3",
		"@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
		"@nomicfoundation/hardhat-ethers": "^3.0.0",
		"@nomicfoundation/hardhat-ignition": "^0.15.0",
		"@nomicfoundation/hardhat-ignition-ethers": "^0.15.0",
		"@nomicfoundation/hardhat-network-helpers": "^1.0.0",
		"@nomicfoundation/hardhat-toolbox": "^5.0.0",
		"@nomicfoundation/hardhat-verify": "^2.0.0",
		"@openzeppelin/contracts": "^5.0.0",
		"@openzeppelin/contracts-upgradeable": "^5.0.0",
		"@typechain/ethers-v6": "^0.5.0",
		"@typechain/hardhat": "^9.0.0",
		"@types/chai": "^4.2.0",
		"@types/mocha": ">=9.1.0",
		"@types/node": ">=18.0.0",
		"chai": "^4.2.0",
		"@cofhe/hardhat-plugin": "^0.4.0",
		"@cofhe/sdk": "^0.4.0",
		"@cofhe/mock-contracts": "^0.4.0",
		"dotenv": "^16.4.7",
		"ethers": "^6.4.0",
		"hardhat": "^2.22.19",
		"hardhat-gas-reporter": "^1.0.8",
		"solidity-coverage": "^0.8.0",
		"ts-node": ">=8.0.0",
		"typechain": "^8.3.0",
		"typescript": ">=4.5.0"
	}
}
